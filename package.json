{
  "name": "wised-air-quality-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Operator-facing dashboard for Berlin's low-cost air-quality sensor network.",
  "scripts": {
    "dev": "vite",
    "mock-api": "node mock-data/server.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.1",
    "@vueuse/core": "^11.1.0",
    "echarts": "^5.5.1",
    "leaflet": "^1.9.4",
    "pinia": "^2.2.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.1",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.7.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.9",
    "vitest": "^2.1.2",
    "vue-tsc": "^2.1.6"
  }
}
